<?xml version="1.0" encoding="utf-8"?>
<!--
  Unipanel v2 Phase 6 — voice-activation pill in the HUD strip.

  Sits next to the clock. Tap to toggle the Gemini voice session via
  the bound GeminiVoiceService (Phase 3 binder; Phase 4 real
  pipeline). Default fill is a muted blue-grey so it reads as
  "actionable but not currently active" at a glance.

  Color is mutated at runtime through backgroundTint to reflect
  HudStateBridge.VoicePhase:
    - IDLE       → this default blue-grey
    - LISTENING  → red (#FFFF3344)
    - THINKING   → amber (#FFFFB347)
    - FOLLOW_UP  → soft red

  Sized 14dp × 14dp at the call-site (larger than the camera dot so
  it's an obvious tap target on the binocular display).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#FF5577AA" />
    <stroke android:width="1dp" android:color="#FFE0F4FF" />
</shape>
