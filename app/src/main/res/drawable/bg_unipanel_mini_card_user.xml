<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 2 Step 2c.2: user-side mini chat card background.

  Mirrors app/src/main/res/drawable/bg_chat_bubble_user.xml with
  the same 10dp-corner adjustment used by the assistant mini card.
  Keeps the user/assistant colour distinction intact so the overlay
  preserves the chat panel's visual rhythm at HUD scale.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#D9305644" />
    <corners android:radius="10dp" />
    <stroke
        android:width="1dp"
        android:color="#BBACFFDD" />
</shape>
