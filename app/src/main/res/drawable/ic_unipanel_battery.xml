<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal battery silhouette for the unipanel HUD strip: a rounded body
     outline with a positive terminal on the right, deliberately a touch wider
     than tall so it reads clearly as a battery next to the charge percentage.
     Drawn in white and tinted at the view via android:drawableTint. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="26dp"
    android:height="13dp"
    android:viewportWidth="26"
    android:viewportHeight="13">
    <!-- Battery body outline -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.3"
        android:fillColor="#00000000"
        android:pathData="M2,2 L20,2 A2,2 0 0 1 22,4 L22,9 A2,2 0 0 1 20,11 L2,11 A2,2 0 0 1 0,9 L0,4 A2,2 0 0 1 2,2 Z" />
    <!-- Positive terminal -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M23.3,4.6 L25.2,4.6 A0.8,0.8 0 0 1 26,5.4 L26,7.6 A0.8,0.8 0 0 1 25.2,8.4 L23.3,8.4 Z" />
</vector>
