<?xml version="1.0" encoding="utf-8"?>
<!--
  Earth orb for the chat panel's voice-activity indicator.
  Rendered as a vector with:
    • deep ocean disc (navy → aqua radial gradient so the sphere reads
      as three-dimensional),
    • organically-shaped green landmasses roughly evoking the Americas,
      Africa/Europe and Asia,
    • soft white cloud wisps,
    • a subtle specular highlight offset toward the upper-left,
    • a hairline atmosphere rim around the limb.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="96dp"
    android:height="96dp"
    android:viewportHeight="200"
    android:viewportWidth="200">

    <!-- Ocean disc.  Radial gradient gives the sphere a rounded, lit look. -->
    <path android:pathData="M100,4 A96,96 0 1 1 99.99,4 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerColor="#FF1867A8"
                android:centerX="0.38"
                android:centerY="0.36"
                android:endColor="#FF05223F"
                android:gradientRadius="110"
                android:startColor="#FF3BB4E6"
                android:type="radial" />
        </aapt:attr>
    </path>

    <!-- Americas (west hemisphere landmass).  Two bulges joined by a
         narrow isthmus. -->
    <path
        android:fillColor="#E55E9C3A"
        android:pathData="M54,52
                          C62,44 74,44 82,52
                          C90,60 88,74 82,82
                          C76,90 64,92 58,86
                          C50,78 46,62 54,52 Z
                          M60,92
                          C66,88 72,92 74,98
                          C78,110 70,126 64,140
                          C58,152 48,156 44,150
                          C40,142 44,132 50,122
                          C54,112 54,96 60,92 Z" />

    <!-- Africa + Europe (central landmass).  A rough silhouette with a
         jut at the north for Europe. -->
    <path
        android:fillColor="#E55E9C3A"
        android:pathData="M98,46
                          C108,42 120,46 126,54
                          C132,62 130,74 124,80
                          C118,86 108,82 104,74
                          C98,68 96,58 98,46 Z
                          M100,86
                          C110,82 122,88 126,100
                          C130,114 124,130 118,142
                          C112,154 102,158 96,152
                          C92,144 94,132 98,120
                          C100,110 94,96 100,86 Z" />

    <!-- Asia (eastern landmass). -->
    <path
        android:fillColor="#E55E9C3A"
        android:pathData="M138,52
                          C148,46 162,50 166,60
                          C170,70 166,82 158,88
                          C150,94 138,92 134,84
                          C128,74 128,60 138,52 Z
                          M148,96
                          C154,92 162,94 164,102
                          C166,112 158,122 150,124
                          C142,126 134,118 136,110
                          C138,104 142,100 148,96 Z" />

    <!-- Cloud wisp across the equator. -->
    <path
        android:fillAlpha="0.35"
        android:fillColor="#FFFFFFFF"
        android:pathData="M40,108
                          C60,100 90,106 120,102
                          C140,100 160,98 170,106
                          C160,118 140,120 120,116
                          C90,112 60,124 40,120
                          C34,118 34,112 40,108 Z" />

    <!-- Cloud wisp near the southern limb. -->
    <path
        android:fillAlpha="0.25"
        android:fillColor="#FFFFFFFF"
        android:pathData="M70,158
                          C90,152 120,154 140,162
                          C130,170 100,172 80,168
                          C72,166 66,162 70,158 Z" />

    <!-- Specular highlight (upper-left). -->
    <path android:pathData="M62,48 m-22,0 a22,14 0 1 0 44,0 a22,14 0 1 0 -44,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerColor="#33FFFFFF"
                android:centerX="0.5"
                android:centerY="0.5"
                android:endColor="#00FFFFFF"
                android:gradientRadius="22"
                android:startColor="#80FFFFFF"
                android:type="radial" />
        </aapt:attr>
    </path>

    <!-- Atmosphere rim. -->
    <path
        android:pathData="M100,4 A96,96 0 1 1 99.99,4 Z"
        android:strokeAlpha="0.55"
        android:strokeColor="#FF9BC7E3"
        android:strokeWidth="1" />
</vector>
